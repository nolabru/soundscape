{
  "expo": {
    "name": "soundscape",
    "slug": "soundscape",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.nolabru.soundscape",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9c2d8319-087d-4f9b-95c5-0dd645f8c832"
      }
    },
    "owner": "nolabrui",
    "plugins": [
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "O Guardião usa o microfone apenas para medir o volume do ambiente — nenhuma voz é gravada."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita o acesso às fotos para definir seu avatar."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usado para enviar sua localização ao contato de emergência durante uma crise."
        }
      ],
      "react-native-audio-api"
    ]
  }
}
